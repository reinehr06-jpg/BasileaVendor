# Copie para .env (na raiz, ao lado do docker-compose.yml) e preencha.
# O docker compose carrega este .env automaticamente para substituir as variaveis.
# NAO comite o .env real.

# Gere uma chave NOVA para producao:  php artisan key:generate --show
APP_KEY=base64:COLOQUE_UMA_APP_KEY_NOVA_AQUI
APP_ENV=production
APP_DEBUG=false
APP_URL=https://vendor.basileia.global

# Banco de dados
DB_DATABASE=basileia_vendas
DB_USERNAME=postgres
DB_PASSWORD=troque_esta_senha

# Frontend
NEXT_PUBLIC_API_URL=https://vendor.basileia.global/api
