# ==========================================
# Configurações de Produção - Render
# ==========================================
# Clone este arquivo para .env e configure os valores

APP_NAME=BasileiaVendas
APP_ENV=production
APP_KEY=base64:GERAR_NOVO_COM artisan_key_generate
APP_DEBUG=false
APP_URL=https://basileiavendas.onrender.com

LOG_CHANNEL=errorlog
LOG_LEVEL=error

# ==========================================
# Banco de Dados Render PostgreSQL
# ==========================================
# O Render fornece estas variáveis automaticamente
DB_CONNECTION=pgsql
DB_HOST=${DB_HOST}
DB_PORT=5432
DB_DATABASE=${DB_DATABASE}
DB_USERNAME=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}

# ==========================================
# Session & Cache
# ==========================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# ==========================================
# Asaas API - 반드시 configurar!
# ==========================================
ASAAS_API_KEY=YOUR_API_KEY_HERE
ASAAS_AMBIENTE=production
ASAAS_WEBHOOK_TOKEN=YOUR_WEBHOOK_TOKEN

# ==========================================
# Mail - Configure seu SMTP
# ==========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=YOUR_MAILTRAP_USERNAME
MAIL_PASSWORD=YOUR_MAILTRAP_PASSWORD
MAIL_FROM_ADDRESS=noreply@basileiachurch.com
MAIL_FROM_NAME="Basiléia Church"