APP_NAME=BasileiaVendas
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://basileiavendas.onrender.com

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=errorlog
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ==========================================
# Render PostgreSQL (Production)
# ==========================================
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=basileia_vendas
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ==========================================
# Asaas - Configurações de Produção
# ==========================================
ASAAS_API_KEY=
ASAAS_AMBIENTE=production
ASAAS_WEBHOOK_TOKEN=

# ==========================================
# Mail - Mailtrap ( configure suas credenciais )
# ==========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=seu_username
MAIL_PASSWORD=sua_senha
MAIL_FROM_ADDRESS=noreply@basileiachurch.com
MAIL_FROM_NAME="Basiléia Church"

# ==========================================
# AWS (Optional)
# ==========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ==========================================
# Segurança de Deploy (AWS/GitHub)
# ==========================================
GIT_DEPLOY_SECRET=

# ==========================================
# Checkout Service - Integração
# ==========================================
CHECKOUT_API_URL=http://localhost:8001
CHECKOUT_API_KEY=ck_live_sua_chave_aqui
CHECKOUT_WEBHOOK_SECRET=seu_webhook_secret_aqui
CHECKOUT_TIMEOUT=30
